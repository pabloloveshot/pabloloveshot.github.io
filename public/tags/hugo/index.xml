    <item>
      <title>Hugo Install</title>
      <link>http://localhost:1313/posts/hugo-install/</link>
      <pubDate>Thu, 26 Mar 2026 15:41:49 +0900</pubDate>
      <guid>http://localhost:1313/posts/hugo-install/</guid>
      <description>&lt;p&gt;Hugo Install(Windows 11에서)&lt;/p&gt;
&lt;p&gt;$ Set-ExecutionPolicy RemoteSigned -Scope CurrentUser&lt;/p&gt;
&lt;p&gt;$ irm get.scoop.sh | iex&lt;/p&gt;
&lt;p&gt;$ scoop install hugo-extended&lt;/p&gt;
&lt;p&gt;$ hugo version&lt;/p&gt;</description>
    </item>
    <item>
      <title>새로운 포스트 만들때</title>
      <link>http://localhost:1313/posts/second-post/</link>
      <pubDate>Thu, 26 Mar 2026 15:31:50 +0900</pubDate>
      <guid>http://localhost:1313/posts/second-post/</guid>
      <description>&lt;p&gt;새로운 포스트 만들때 git 사용법&lt;/p&gt;
&lt;p&gt;$ git clone &lt;a href=&#34;https://github.com/pabloloveshot/pabloloveshot.github.io&#34;&gt;https://github.com/pabloloveshot/pabloloveshot.github.io&lt;/a&gt;&lt;/p&gt;
&lt;p&gt;$ hugo new posts/second-post.md ==&amp;gt; draft: false&lt;/p&gt;
&lt;p&gt;$ git add .&lt;/p&gt;
&lt;p&gt;$ git commit -m &amp;ldquo;Add second post&amp;rdquo;&lt;/p&gt;
&lt;p&gt;$ git push&lt;/p&gt;</description>
